@implements IAsyncDisposable

@* Hidden detector: when the camera indicator is enabled, runs face detection off-screen and
   raises OnIndicated each time the user's trained gesture fires — the same effect as the helper
   pressing the button. Renders nothing visible when disabled. *@
@if (Config.IsEnabled)
{
    <video @ref=Video class="bt-cam-hidden" autoplay playsinline muted></video>
}


