@page "/type"
@implements IDisposable

<div class="bt-root"
     style="--bt-hl-color: @DepthColor"
     tabindex="0"
     @ref=Root
     @onpointerdown=OnIndicate
     @onkeydown=OnKeyDown
     @onkeydown:preventDefault="true">

    <button class="bt-settings-button"
            title="Settings"
            @onpointerdown:stopPropagation="true"
            @onpointerdown=GoToSettings>⚙</button>

    <!-- Current sentence -->
    <div class="bt-sentence @(Controller.Sentence.ShouldClearOnNextInput ? "bt-pending" : "")">
        @if (string.IsNullOrEmpty(SentenceText))
        {
            <span class="bt-sentence-placeholder">…</span>
        }
        else
        {
            @* Committed words read as a normal sentence; the word being edited sits in a box
               (empty after a space, showing a new word has been started). *@
            @CommittedText<span class="bt-current-word">@CurrentWord</span>
        }
    </div>

    <!-- Word suggestions -->
    <div class="bt-section bt-words @SectionClass(Section.WordSelector) @WordsContextClass">
        @if (Words.Count == 0)
        {
            <span class="bt-words-empty">no suggestions</span>
        }
        else
        {
            @for (int i = 0; i < Words.Count; i++)
            {
                <span class="bt-word @WordClass(i)">@Words[i]</span>
            }
        }
    </div>

    <!-- Keyboard -->
    <div class="bt-section bt-keyboard @SectionClass(Section.Keyboard) @KeyboardContextClass">
        @for (int r = 0; r < Rows.Count; r++)
        {
            int rowIndex = r;
            <div class="bt-row @RowClass(rowIndex)">
                @for (int c = 0; c < Rows[rowIndex].Count; c++)
                {
                    int colIndex = c;
                    var key = Rows[rowIndex][colIndex];
                    <span class="bt-key @(key == KeyCode.Space ? "bt-key-wide" : "") @KeyClass(rowIndex, colIndex)">
                        @KeyDisplay.Label(key)
                    </span>
                }
            </div>
        }
    </div>

    <!-- Speak -->
    <div class="bt-section bt-speak @SectionClass(Section.Speak)">
        SPEAK
    </div>

    @* When the camera indicator is enabled+trained, it triggers its own indicator, which the
       controller subscribes to just like the pointer and keyboard. *@
    <CameraIndicator />
</div>


