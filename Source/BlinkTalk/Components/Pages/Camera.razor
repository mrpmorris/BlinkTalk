@page "/camera"
@using BlinkTalk.Services
@using BlinkTalk.Application.Abstractions
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject CameraIndicatorConfig Config
@inject ITextToSpeechService Speech
@inject NavigationManager Navigation

<div class="bt-settings bt-cam-page @(Flash ? "bt-cam-flash" : "")">
    <div class="bt-cam-top">
        <div class="bt-cam-feed">
            <video @ref="Video" autoplay playsinline muted></video>
        </div>

        <div class="bt-cam-actions">
            <button class="bt-settings-back" @onclick="TrainAsync" disabled="@Busy">@(Busy ? "Training…" : "Train")</button>
            @if (Error is not null)
            {
                <p class="bt-cam-error">@Error</p>
            }
            <p class="bt-cam-status">@Status</p>
        </div>
    </div>

    <div class="bt-cam-scroll">
        @if (SignalDescription is not null)
        {
            <div class="bt-setting-row">
                <h2>Eye gesture</h2>
                <label>Learned gesture: <strong>@SignalDescription</strong></label>
                <div class="bt-meter"><div class="bt-meter-fill" style="width:@($"{(int)(HoldFraction * 100)}%")"></div></div>
                <label for="holdTime">Hold time: @DwellSeconds.ToString("0.0") s</label>
                Hold your gesture and the bar fill with time. Set the slider where you'd like it to trigger. You'll hear a beep when the bar reaches it.
                <input id="holdTime"
                       type="range"
                       min="0.1"
                       max="2.0"
                       step="0.1"
                       value="@DwellSeconds"
                       @oninput="OnDwellChanged" />
            </div>
        }

        <label class="bt-cam-check">
            <input type="checkbox"
                   checked="@Config.IsEnabled"
                   disabled="@(!Config.IsTrained || Busy)"
                   @onchange="OnUseCameraChanged" />
            Use camera @(Config.IsTrained ? "" : "(train first)")
        </label>

        <button class="bt-settings-back" @onclick="GoBack">Done</button>
    </div>
</div>


