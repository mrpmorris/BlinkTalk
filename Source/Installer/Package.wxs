<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="BlinkTalk"
           Manufacturer="Air Software Limited"
           Version="$(var.ProductVersion)"
           UpgradeCode="7E3B9A42-2C1D-4F58-9B6E-0A1C2D3E4F50"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="BlinkTalk single-switch communication app" />

    <!-- Uninstall the previous version automatically when a newer one is installed. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Directories -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="BlinkTalk" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="BlinkTalk" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />

    <!-- Application payload: every file from the self-contained publish output is
         harvested at build time, preserving the wwwroot/ subfolder structure. -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**" />
    </ComponentGroup>

    <!-- Start Menu shortcut -->
    <Component Id="StartMenuShortcut" Directory="AppMenuFolder" Guid="9C4D5E6F-1A2B-3C4D-5E6F-7A8B9C0D1E2F">
      <Shortcut Id="StartMenuBlinkTalk"
                Name="BlinkTalk"
                Description="Single-switch communication app"
                Target="[INSTALLFOLDER]BlinkTalk.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\Air Software Limited\BlinkTalk" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!-- Desktop shortcut -->
    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="B1C2D3E4-F5A6-4B7C-8D9E-0F1A2B3C4D5E">
      <Shortcut Id="DesktopBlinkTalk"
                Name="BlinkTalk"
                Description="Single-switch communication app"
                Target="[INSTALLFOLDER]BlinkTalk.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU" Key="Software\Air Software Limited\BlinkTalk" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Feature Id="Main" Title="BlinkTalk" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- Install wizard: welcome → license → choose folder → progress → finish. -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

  </Package>
</Wix>
